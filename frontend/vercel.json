{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/browser",
  "framework": "angular",
  "rewrites": [
    { "source": "/auth/(.*)", "destination": "https://projectoavanzada-production.up.railway.app/auth/$1" },
    { "source": "/solicitudes/(.*)", "destination": "https://projectoavanzada-production.up.railway.app/solicitudes/$1" },
    { "source": "/sugerencias/(.*)", "destination": "https://projectoavanzada-production.up.railway.app/sugerencias/$1" },
    { "source": "/usuarios/(.*)", "destination": "https://projectoavanzada-production.up.railway.app/usuarios/$1" }
  ]
}